# ═══════════════════════════════════════════════════════
# Bank Simulator - Variables compartidas de infraestructura
# ═══════════════════════════════════════════════════════
# Copia este archivo como .env y ajusta los valores.
# Las variables específicas de cada servicio están en
# su propio .env dentro de cada carpeta.

# ─── MySQL ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your_strong_password
MYSQL_HOST_PORT=3307

# ─── Shared (inyectado a todos los servicios) ──────────
DB_USERNAME=root
DB_PASSWORD=your_password
JPA_DDL_AUTO=update
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
DOCKER_COMPOSE_ENABLED=false

# ─── Frontend ──────────────────────────────────────────
API_PROXY_TARGET=http://api-gateway:8000
